# Copy to terraform.tfvars and fill in. Do NOT commit the real file.
aiven_project = "your-aiven-project-name"

# Akamai (Linode)-backed regions. Run `aiven cloud list | grep akamai` to see
# what your project can reach.
cloud_name = "akamai-us-east"

# valkey-search is included on all Aiven for Valkey plans.
valkey_plan  = "startup-4"
service_name = "few-shot-valkey"
